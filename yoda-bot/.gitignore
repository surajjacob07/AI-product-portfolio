# Yoda Bot — .gitignore

# Environment / secrets — NEVER commit these
config/.env
*.env
.env.*

# Python
__pycache__/
*.py[cod]
*.pyo
venv/
.venv/
env/
*.egg-info/
dist/
build/

# Logs — local only
logs/
!logs/.gitkeep

# macOS
.DS_Store
.AppleDouble
.LSOverride

# IDE
.vscode/
.idea/
*.swp
*.swo

# Test outputs
.pytest_cache/
htmlcov/
.coverage
