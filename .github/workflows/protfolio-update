name: Bi-Weekly Portfolio Update

on:
  schedule:
    - cron: '0 9 * * 1'   # Every Monday 9am UTC
    - cron: '0 9 * * 4'   # Every Thursday 9am UTC
  workflow_dispatch:       # Enables manual "Run workflow" button

jobs:
  update-portfolio:
    runs-on: ubuntu-latest

    steps:
      - name: Checkout repo
        uses: actions/checkout@v3
        with:
          token: ${{ secrets.PORTFOLIO_TOKEN }}

      - name: Update timestamp
        run: |
          DATE=$(date '+%Y-%m-%d %H:%M UTC')
          echo "Last updated: $DATE" > LAST_UPDATED.txt
          git config user.name "Suraj Jacob Bot"
          git config user.email "suraj.jacob07@gmail.com"
          git add .
          git diff --cached --quiet || git commit -m "chore: portfolio update $DATE"
          git push
